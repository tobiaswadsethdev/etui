{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vault Desktop",
  "version": "0.1.0",
  "identifier": "com.etui.vault.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Vault Desktop",
        "width": 1000,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
